generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  password    String
  name        String
  role        String       @default("student")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  classes     Class[]      @relation("TeacherClasses")
  enrollments Enrollment[]
  ledTeams    Team[]       @relation("TeamLeader")
  teamMembers TeamMember[]
}

model Enrollment {
  id        Int      @id @default(autoincrement())
  studentId Int
  classId   Int
  joinDate  DateTime @default(now())
  class     Class    @relation(fields: [classId], references: [id], onUpdate: NoAction)
  student   User     @relation(fields: [studentId], references: [id], onUpdate: NoAction)

  @@unique([studentId, classId])
}

model Class {
  id          Int          @id @default(autoincrement())
  classCode   String       @unique
  className   String
  teacherId   Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  teacher     User         @relation("TeacherClasses", fields: [teacherId], references: [id], onUpdate: NoAction)
  enrollments Enrollment[]
  milestones  Milestone[]
  teams       Team[]
}

model Team {
  id          Int          @id @default(autoincrement())
  teamName    String
  topic       String?
  status      String       @default("PENDING")
  classId     Int
  leaderId    Int?
  submissions Submission[]
  class       Class        @relation(fields: [classId], references: [id], onUpdate: NoAction)
  leader      User?        @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  members     TeamMember[]
}

model TeamMember {
  id     Int  @id @default(autoincrement())
  teamId Int
  userId Int
  team   Team @relation(fields: [teamId], references: [id], onUpdate: NoAction)
  user   User @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@unique([teamId, userId])
}

model Milestone {
  id          Int          @id @default(autoincrement())
  title       String
  description String?      @db.NVarChar(Max)
  dueDate     DateTime
  classId     Int
  class       Class        @relation(fields: [classId], references: [id], onUpdate: NoAction)
  submissions Submission[]
}

model Submission {
  id             Int       @id @default(autoincrement())
  fileUrl        String
  submitTime     DateTime  @default(now())
  score          Float?
  reviewComments String?   @db.NVarChar(Max)
  status         String    @default("SUBMITTED")
  teamId         Int
  milestoneId    Int
  milestone      Milestone @relation(fields: [milestoneId], references: [id], onUpdate: NoAction)
  team           Team      @relation(fields: [teamId], references: [id], onUpdate: NoAction)
}
